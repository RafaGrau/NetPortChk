// IDD_CONFIG_EDITOR
// Layout: toolbar strip (created dynamically at y=0..~22) |
//         server form row (y=26..40) | separator (y=42) |
//         tab+list (y=44..289) | bottom row (y=302)

IDD_CONFIG_EDITOR DIALOGEX 0, 0, 410, 312
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Configuraci�n de servidores"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    // -- Server form row (left-aligned). RepositionFormRow() snaps flush below toolbar.
    LTEXT           "Nombre:",IDC_CFG_LBL_NAME,7,26,36,8
    EDITTEXT        IDC_CFG_EDIT_NAME,45,24,100,12,ES_AUTOHSCROLL|WS_TABSTOP
    LTEXT           "IP:",IDC_CFG_LBL_IP,153,26,14,8
    CONTROL         "",IDC_CFG_EDIT_IP,"SysIPAddress32",WS_CHILD|WS_VISIBLE|WS_BORDER|WS_TABSTOP,169,24,88,12
    LTEXT           "Tipo:",IDC_CFG_LBL_TYPE,265,26,24,8
    COMBOBOX        IDC_CFG_COMBO_TYPE,291,24,110,60,CBS_DROPDOWNLIST|WS_VSCROLL|WS_TABSTOP

    // -- Separator
    CONTROL         "",IDC_CFG_TOOLBAR_SEP,"Static",SS_ETCHEDHORZ|WS_CHILD|WS_VISIBLE,0,38,410,1

    // -- Tab + list
    CONTROL         "",IDC_CFG_TAB,"SysTabControl32",TCS_TABS|WS_CHILD|WS_VISIBLE|WS_TABSTOP|WS_CLIPSIBLINGS,7,40,396,248
    CONTROL         "",IDC_CFG_LIST,"SysListView32",LVS_REPORT|LVS_SHOWSELALWAYS|LVS_SINGLESEL|WS_CHILD|WS_VISIBLE|WS_BORDER|WS_TABSTOP,14,61,382,222

    // -- Bottom row: Timeout (left) + OK/Cancel (right)
    LTEXT           "Timeout:",IDC_STATIC,7,296,30,8
    COMBOBOX        IDC_CFG_COMBO_TIMEOUT,40,294,80,50,CBS_DROPDOWNLIST|WS_TABSTOP
    DEFPUSHBUTTON   "Aceptar",IDOK,285,294,60,14
    PUSHBUTTON      "Cancelar",IDCANCEL,350,294,55,14
END

