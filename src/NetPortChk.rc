// ----------------------------------------------------------------------------
// IDD_ABOUT
// ----------------------------------------------------------------------------
IDD_ABOUT DIALOGEX 0, 0, 270, 146
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Acerca de NetPortChk"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    // Fila 1: icono app + nombre + subtitulo
    ICON            IDR_MAINFRAME, IDC_STATIC, 8, 8, 32, 32
    LTEXT           "NetPortChk  (x64)", IDC_STATIC, 48, 10, 210, 12
    LTEXT           "Comprobador de conectividad TCP/UDP", IDC_STATIC, 48, 24, 210, 10
    LTEXT           "", IDC_ABOUT_VERSION, 48, 36, 210, 10

    CONTROL         "", IDC_STATIC, "Static", SS_ETCHEDHORZ, 6, 50, 258, 1

    // Fila 2: icono GitHub + enlace URL
    ICON            IDI_ICON_GITHUB, IDC_STATIC, 8, 56, 16, 16
    CONTROL         "", IDC_ABOUT_LINK_GITHUB, "SysLink", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 30, 58, 232, 12

    CONTROL         "", IDC_STATIC, "Static", SS_ETCHEDHORZ, 6, 76, 258, 1

    // Licencia
    LTEXT           "General Public License v3.0", IDC_STATIC, 8, 82, 254, 10

    // Iconos
    LTEXT           "Iconos:", IDC_STATIC, 8, 96, 28, 10
    CONTROL         "", IDC_ABOUT_LINK_ICONS8, "SysLink", WS_CHILD | WS_VISIBLE | WS_TABSTOP, 38, 96, 224, 12

    DEFPUSHBUTTON   "Aceptar", IDOK, 202, 126, 60, 14
END

